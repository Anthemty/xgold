# =====================
# 服务配置
# =====================
PORT=4000
NODE_ENV=development

# =====================
# Supabase（必需）
# 使用 service_role_key，拥有完整写权限，绝对不能暴露给前端
# 获取：Supabase Dashboard → 项目 → Settings → API
# =====================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# =====================
# Gold API（必需，用于价格采集）
# 获取：https://www.goldapi.io → 注册后在 Dashboard 获取
# =====================
GOLD_API_KEY=your_goldapi_key

# =====================
# API 鉴权（必需）
# 所有 /api/* 路由需要此 Key
# 请求时在 Header 传入：X-API-Key: <your-api-key>
# =====================
API_KEY=your-api-key-here

# =====================
# 定时任务配置
# 单位：毫秒
# 请根据 Gold API 套餐合理设置：
#   Free  (100次/月)  → 建议 >= 26000000（约 7.2 小时）
#   Basic (1000次/月) → 建议 >= 2600000 （约 43 分钟）
#   Pro   (10000次/月)→ 建议 >= 300000  （5 分钟）
# =====================
PRICE_SYNC_INTERVAL_MS=300000

# =====================
# CORS 配置
# 多个域名用逗号分隔，例如：http://localhost:3000,https://your-domain.com
# =====================
CORS_ORIGIN=http://localhost:3000
